generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

enum Gender {
  Male
  Female
  Transgender
  RatherNotSay
}

enum MaritalStatus {
  Married
  Unmarried
}

enum ReviewType {
  first_visit
  repeat
}

enum VisitType {
  qr_scan
  payment
}

enum AutomationType {
  birthday_whatsapp
  birthday_email
  anniversary_whatsapp
  anniversary_email
  reengagement_whatsapp
  reengagement_email
  welcome_whatsapp
  welcome_email
  promotional_whatsapp
  promotional_email
  announcement_whatsapp
  announcement_email
  bounceback_whatsapp
  bounceback_email
}

enum MessageStage {
  five_days_before
  one_day_before
  thirty_days_inactive
  on_day
  on_registration
  manual_campaign
}

enum AutomationStatus {
  success
  failed
}

enum StaffRole {
  admin
  owner
  franchise_owner
  main_owner
}

enum OrderStatus {
  new
  preparing
  ready
  served
  cancelled
}

enum OrderSource {
  customer
  staff
}

enum ServiceType {
  table
  self
}

enum CancelledBy {
  staff
  customer
}

model Outlet {
  id            String   @id @default(uuid()) @db.Uuid
  code          String   @unique @db.VarChar(10)
  slug          String   @unique @db.VarChar(50)
  name          String
  location      String?
  address       String?
  googlePlaceId String   @unique
  googleMapsUrl String?
  instagramUrl  String?
  facebookUrl   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customers      Customer[]      @relation("FirstVisitOutlet")
  reviews        Review[]
  visits         CustomerVisit[]
  menuCategories MenuCategory[]
  staff          Staff[]
  orders         Order[]

  @@map("outlets")
}

model Customer {
  id                      String        @id @default(uuid()) @db.Uuid
  deviceId                String        @unique
  fullName                String
  phone                   String        @unique @db.VarChar(15)
  email                   String?
  birthDate               DateTime      @db.Date
  anniversaryDate         DateTime?     @db.Date
  gender                  Gender
  maritalStatus           MaritalStatus
  firstVisitOutletId      String?       @db.Uuid
  firstVisitOutlet        Outlet?       @relation("FirstVisitOutlet", fields: [firstVisitOutletId], references: [id])
  lastVisitDate           DateTime?
  totalVisits             Int           @default(1)
  hasSubmittedFirstReview Boolean       @default(false)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  reviews        Review[]
  visits         CustomerVisit[]
  automationLogs AutomationLog[]
  orders         Order[]

  @@index([deviceId])
  @@index([phone])
  @@index([lastVisitDate])
  @@index([birthDate])
  @@index([anniversaryDate])
  @@map("customers")
}

model Review {
  id                String     @id @default(uuid()) @db.Uuid
  customerId        String?    @db.Uuid
  customer          Customer?  @relation(fields: [customerId], references: [id])
  outletId          String     @db.Uuid
  outlet            Outlet     @relation(fields: [outletId], references: [id])
  reviewText        String?
  stars             Int
  reviewType        ReviewType
  postedToGoogle    Boolean    @default(false)
  isVisible         Boolean    @default(true)
  sentimentLabel    String?
  sentimentScore    Decimal?   @db.Decimal(4, 3)
  sentimentKeywords String[]   @default([])
  createdAt         DateTime   @default(now())

  @@index([outletId, createdAt])
  @@index([customerId])
  @@index([sentimentLabel])
  @@map("reviews")
}

model CustomerVisit {
  id         String    @id @default(uuid()) @db.Uuid
  customerId String?   @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id])
  deviceId   String
  outletId   String    @db.Uuid
  outlet     Outlet    @relation(fields: [outletId], references: [id])
  visitType  VisitType @default(qr_scan)
  visitedAt  DateTime  @default(now())

  @@index([customerId, visitedAt])
  @@index([deviceId, visitedAt])
  @@index([outletId, visitedAt])
  @@map("customer_visits")
}

model MenuCategory {
  id           String     @id @default(uuid()) @db.Uuid
  name         String
  displayOrder Int?
  isActive     Boolean    @default(true)
  outletId     String?    @db.Uuid
  outlet       Outlet?    @relation(fields: [outletId], references: [id])
  createdAt    DateTime   @default(now())
  items        MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id            String       @id @default(uuid()) @db.Uuid
  categoryId    String       @db.Uuid
  category      MenuCategory @relation(fields: [categoryId], references: [id])
  name          String
  description   String?
  price         Decimal?     @db.Decimal(10, 2)
  priceVariants Json?
  isVeg         Boolean      @default(true)
  imageUrl      String?      @db.VarChar(500)
  isAvailable   Boolean      @default(true)
  displayOrder  Int?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  orderItems    OrderItem[]

  @@index([categoryId, displayOrder])
  @@map("menu_items")
}

model AutomationLog {
  id             String           @id @default(uuid()) @db.Uuid
  customerId     String?          @db.Uuid
  customer       Customer?        @relation(fields: [customerId], references: [id])
  automationType AutomationType
  messageStage   MessageStage
  status         AutomationStatus
  errorMessage   String?
  sentAt         DateTime         @default(now())

  @@index([customerId, sentAt])
  @@index([automationType, status])
  @@map("automation_logs")
}

model Staff {
  id               String    @id @db.Uuid
  username         String?   @unique
  fullName         String
  email            String    @unique
  phone            String?   @db.VarChar(15)
  role             StaffRole
  isAdmin          Boolean   @default(false)
  assignedOutletId String?   @db.Uuid
  assignedOutlet   Outlet?   @relation(fields: [assignedOutletId], references: [id])
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("staff")
}

model Order {
  id          String       @id @default(uuid()) @db.Uuid
  outletId    String       @db.Uuid
  outlet      Outlet       @relation(fields: [outletId], references: [id])
  customerId  String?      @db.Uuid
  customer    Customer?    @relation(fields: [customerId], references: [id])
  deviceId    String? // links guest orders to a device (my-orders history + tracking)
  createdById String?      @db.Uuid // Staff.id when source = staff (plain field, no relation)
  status      OrderStatus  @default(new)
  source      OrderSource
  serviceType ServiceType  @default(table)
  boardNumber String?      @db.VarChar(10)
  note        String?
  cancelledBy CancelledBy? // who cancelled, when status = cancelled
  closedAt    DateTime? // set when the order reaches a terminal state (served/cancelled)
  dailyNumber Int? // per-outlet token number, resets each business day (IST)
  businessDate DateTime?   @db.Date // the IST business day this order belongs to
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  items OrderItem[]

  @@index([outletId, status, createdAt])
  @@index([outletId, closedAt])
  @@index([outletId, businessDate])
  @@index([deviceId])
  @@map("orders")
}

// Per-outlet, per-day sequence source for order token numbers. One row per
// (outlet, business day); `lastNumber` is atomically incremented on each order
// (see createOrderWithItems). A fresh day starts a new row → numbers reset daily.
model OrderCounter {
  id         String   @id @default(uuid()) @db.Uuid
  outletId   String   @db.Uuid
  date       DateTime @db.Date
  lastNumber Int      @default(0)

  @@unique([outletId, date])
  @@map("order_counters")
}

model OrderItem {
  id            String    @id @default(uuid()) @db.Uuid
  orderId       String    @db.Uuid
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId    String?   @db.Uuid // nullable: keep row if the menu item is later deleted
  menuItem      MenuItem? @relation(fields: [menuItemId], references: [id])
  nameSnapshot  String
  variantLabel  String? // chosen price variant, e.g. "Large" / "nonVeg"
  priceSnapshot Decimal?  @db.Decimal(10, 2)
  quantity      Int       @default(1)
  note          String?

  @@index([orderId])
  @@map("order_items")
}
